datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// -------------------------------------------------------------
// ENUMS
// -------------------------------------------------------------
enum Role {
  STUDENT
  RECRUITER
  ADMIN
}

// -------------------------------------------------------------
// USER MODEL
// -------------------------------------------------------------
model User {
  id            String    @id @default(uuid())
  email         String    @unique
  name          String?
  role          Role      @default(STUDENT)
  isBanned      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relation to Recruiter profile
  recruiter     Recruiter?

  @@map("users")
}

// -------------------------------------------------------------
// RECRUITER MODEL
// -------------------------------------------------------------
model Recruiter {
  id                 String   @id @default(uuid())
  name               String   // Recruiter's personal name
  email              String   @unique
  
  // Link to User account
  userId             String?  @unique
  user               User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Company Details
  companyName        String
  companyDescription String?
  companyLogoColor   String?  // Replaces the logoColor on the individual job
  
  createdAt          DateTime @default(now())
  
  // Admin Management Fields
  isVerified         Boolean  @default(false)
  verificationStatus String   @default("Pending") // Pending, Approved, Rejected
  
  // A recruiter can post multiple jobs
  jobs               Job[]

  @@map("recruiters")
}

// -------------------------------------------------------------
// JOB MODEL
// -------------------------------------------------------------
model Job {
  id            String        @id // Using the existing SEO-friendly slugs
  title         String
  location      String
  type          String        // e.g., "Full-time", "Internship", etc.
  salaryRange   String?
  postedAt      DateTime      @default(now())
  tags          String[]      // PostgreSQL supports string arrays
  status        String        @default("Published")
  description   String?       // Full job description
  
  // Relation back to the Recruiter
  recruiterId   String
  recruiter     Recruiter     @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  
  // Relation to applications
  applications  Application[]

  @@map("jobs")
}

// -------------------------------------------------------------
// APPLICATION MODEL
// -------------------------------------------------------------
model Application {
  id            String   @id @default(uuid())
  
  // Foreign Key to the Job model
  jobId         String
  job           Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  
  // Applicant details from the Apply Modal
  name          String
  email         String
  portfolioUrl  String?
  coverLetter   String?
  
  createdAt     DateTime @default(now())
  status        String   @default("Pending") // Pending, Reviewed, Shortlisted, Rejected

  @@map("applications")
}
